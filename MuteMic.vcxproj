<?xml version="1.0" encoding="utf-8"?>
<!--
  MuteMic.vcxproj — WinUI 3 C++/WinRT desktop app
  Mirrors the working NUCSoftwareStudio vcxproj:
  NO ApplicationType, NO CppWinRTEnabled (UWP-only props).
  WinUI 3 desktop = Win32Proj + WindowsPackageType=None + NuGet via Directory.Build.props.
-->
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <PreferredToolArchitecture>x64</PreferredToolArchitecture>
  </PropertyGroup>

  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <ProjectGuid>{7A1C3D52-9B4E-4C21-A3F0-5D2E8A16C9B4}</ProjectGuid>
    <Keyword>Win32Proj</Keyword>
    <RootNamespace>MuteMic</RootNamespace>
    <ProjectName>MuteMic</ProjectName>
    <WindowsTargetPlatformVersion>10.0.26100.0</WindowsTargetPlatformVersion>
    <Platform>x64</Platform>
    <AppxPackageSigningEnabled>false</AppxPackageSigningEnabled>
    <WindowsAppSDKDeploymentManagerInitialize>false</WindowsAppSDKDeploymentManagerInitialize>
    <WindowsAppSDKUndockedRegFreeWinRTInitialize>false</WindowsAppSDKUndockedRegFreeWinRTInitialize>
    <VCProjectUpgraderObjectName>NoUpgrade</VCProjectUpgraderObjectName>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <CharacterSet>Unicode</CharacterSet>
    <PlatformToolset>v143</PlatformToolset>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <CharacterSet>Unicode</CharacterSet>
    <PlatformToolset>v143</PlatformToolset>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <!-- NO importar CppWinRT props/targets a mano: NuGet ya los importa vía
       obj\*.nuget.g.props/targets (duplicarlos dispara MSB4011). -->
  <ImportGroup Label="ExtensionSettings">
  </ImportGroup>
  <ImportGroup Label="PropertySheets">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props" Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')" Label="LocalAppDataPlatform" />
  </ImportGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <ClCompile>
      <PrecompiledHeader>Use</PrecompiledHeader>
      <PrecompiledHeaderFile>pch.h</PrecompiledHeaderFile>
      <LanguageStandard>stdcpp20</LanguageStandard>
      <AdditionalIncludeDirectories>$(ProjectDir);$(IntDir);$(IntDir)Generated Files;$(ProjectDir)Generated Files;$(ProjectDir)Generated Files\Themes;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <AdditionalOptions>%(AdditionalOptions) /Zc:__cplusplus /utf-8 /await</AdditionalOptions>
      <ConformanceMode>true</ConformanceMode>
      <ExceptionHandling>Sync</ExceptionHandling>
      <Optimization>Disabled</Optimization>
      <PreprocessorDefinitions>_DEBUG;UNICODE;_UNICODE;NOMINMAX;DISABLE_XAML_GENERATED_MAIN;DISABLE_XAML_GENERATED_MAIN=1;Microsoft_Windows_App_Foundation_Bootstrap_DisableAutoInitializer;Microsoft_Windows_App_Foundation_Bootstrap_DisableAutoInitializer=1;WINRT_FORCE_INCLUDE_APP_XAML_G_H;WINRT_FORCE_INCLUDE_MAINWINDOW_XAML_G_H;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <RuntimeLibrary>MultiThreadedDebugDLL</RuntimeLibrary>
    </ClCompile>
    <Midl>
      <AdditionalIncludeDirectories>$(ProjectDir);%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </Midl>
    <Link>
      <SubSystem>Windows</SubSystem>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <AdditionalDependencies>windowsapp.lib;user32.lib;shell32.lib;comctl32.lib;ole32.lib;gdi32.lib;gdiplus.lib;advapi32.lib;winmm.lib;wtsapi32.lib;dwmapi.lib;d3d11.lib;dxgi.lib;xinput9_1_0.lib;Microsoft.WindowsAppRuntime.Bootstrap.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <DelayLoadDLLs>Microsoft.ui.xaml.dll</DelayLoadDLLs>
    </Link>
  </ItemDefinitionGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <ClCompile>
      <PrecompiledHeader>Use</PrecompiledHeader>
      <PrecompiledHeaderFile>pch.h</PrecompiledHeaderFile>
      <LanguageStandard>stdcpp20</LanguageStandard>
      <AdditionalIncludeDirectories>$(ProjectDir);$(IntDir);$(IntDir)Generated Files;$(ProjectDir)Generated Files;$(ProjectDir)Generated Files\Themes;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <AdditionalOptions>%(AdditionalOptions) /Zc:__cplusplus /utf-8 /await /FS</AdditionalOptions>
      <ConformanceMode>true</ConformanceMode>
      <ExceptionHandling>Sync</ExceptionHandling>
      <Optimization>MaxSpeed</Optimization>
      <PreprocessorDefinitions>NDEBUG;UNICODE;_UNICODE;NOMINMAX;DISABLE_XAML_GENERATED_MAIN;DISABLE_XAML_GENERATED_MAIN=1;Microsoft_Windows_App_Foundation_Bootstrap_DisableAutoInitializer;Microsoft_Windows_App_Foundation_Bootstrap_DisableAutoInitializer=1;WINRT_FORCE_INCLUDE_APP_XAML_G_H;WINRT_FORCE_INCLUDE_MAINWINDOW_XAML_G_H;%(PreprocessorDefinitions);WINAPI_FAMILY=100</PreprocessorDefinitions>
      <RuntimeLibrary>MultiThreadedDLL</RuntimeLibrary>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
    </ClCompile>
    <Midl>
      <AdditionalIncludeDirectories>$(ProjectDir);%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </Midl>
    <Link>
      <SubSystem>Windows</SubSystem>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <AdditionalDependencies>windowsapp.lib;user32.lib;shell32.lib;comctl32.lib;ole32.lib;gdi32.lib;gdiplus.lib;advapi32.lib;winmm.lib;wtsapi32.lib;dwmapi.lib;d3d11.lib;dxgi.lib;xinput9_1_0.lib;Microsoft.WindowsAppRuntime.Bootstrap.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <DelayLoadDLLs>Microsoft.ui.xaml.dll</DelayLoadDLLs>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
    </Link>
  </ItemDefinitionGroup>

  <ItemGroup>
    <Midl Include="App.idl" />
    <Midl Include="MainWindow.idl" />
  </ItemGroup>

  <ItemGroup>
    <ApplicationDefinition Include="App.xaml" />
    <Page Include="MainWindow.xaml" />
    <Page Include="Themes\Colors.xaml" />
    <Page Include="Themes\Styles.xaml" />
  </ItemGroup>

  <ItemGroup>
    <ClCompile Include="pch.cpp">
      <PrecompiledHeader>Create</PrecompiledHeader>
    </ClCompile>
    <ClCompile Include="App.xaml.cpp" />
    <ClCompile Include="MainWindow.xaml.cpp" />
    <ClCompile Include="Core\AudioController.cpp" />
    <ClCompile Include="Core\Autostart.cpp" />
    <ClCompile Include="Core\HotkeyHook.cpp" />
    <ClCompile Include="Core\IconRenderer.cpp" />
    <ClCompile Include="Core\LiquidGlassBackdrop.cpp" />
    <ClCompile Include="Core\MuteMicCore.cpp" />
    <ClCompile Include="Core\SettingsStore.cpp" />
    <ClCompile Include="Core\TrayIcon.cpp" />
    <ClCompile Include="Core\VisualCue.cpp" />
    <ClCompile Include="XamlGeneratedBodies.cpp">
      <PrecompiledHeader>NotUsing</PrecompiledHeader>
    </ClCompile>
    <!-- Tablas de tipos: generadas por MarkupCompilePass2 en $(IntDir),
         siempre en sync con los .xaml (no las versionamos). -->
    <ClCompile Include="$(IntDir)XamlTypeInfo.g.cpp" />
    <!-- Infraestructura genérica del provider: versionada en Generated Files\
         (el XAML compiler no la genera con WindowsPackageType=None). -->
    <ClCompile Include="Generated Files\XamlTypeInfo.Impl.g.cpp" />
    <ClCompile Include="Generated Files\XamlMetaDataProvider.cpp" />
  </ItemGroup>

  <ItemGroup>
    <ClInclude Include="pch.h" />
    <ClInclude Include="App.xaml.h" />
    <ClInclude Include="MainWindow.xaml.h" />
    <ClInclude Include="Core\AudioController.h" />
    <ClInclude Include="Core\Autostart.h" />
    <ClInclude Include="Core\HotkeyHook.h" />
    <ClInclude Include="Core\IconRenderer.h" />
    <ClInclude Include="Core\LiquidGlassBackdrop.h" />
    <ClInclude Include="Core\MuteMicCore.h" />
    <ClInclude Include="Core\SettingsStore.h" />
    <ClInclude Include="Core\TrayIcon.h" />
    <ClInclude Include="Core\VisualCue.h" />
  </ItemGroup>

  <ItemGroup>
    <Manifest Include="app.manifest" />
    <ResourceCompile Include="MuteMic.rc" />
    <!-- El .ico también junto al exe: AppWindow.SetIcon lo carga por ruta. -->
    <Content Include="app.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!-- Catálogo de tonos: se copia junto al exe (Sounds\mute, Sounds\unmute). -->
  <ItemGroup>
    <Content Include="Sounds\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!-- Shader del Liquid Glass: se compila con fxc como custom effect D2D
       (ps_4_0 + d2d1effecthelpers.hlsli) → LiquidGlass.cso junto al exe. -->
  <ItemGroup>
    <FxCompile Include="Core\LiquidGlass.hlsl">
      <ShaderType>Pixel</ShaderType>
      <ShaderModel>4.0</ShaderModel>
      <EntryPointName>main</EntryPointName>
      <ObjectFileOutput>$(OutDir)LiquidGlass.cso</ObjectFileOutput>
      <AdditionalOptions>/D D2D_FULL_SHADER /D D2D_ENTRY=main %(AdditionalOptions)</AdditionalOptions>
      <AdditionalIncludeDirectories>$(WindowsSdkDir)Include\$(WindowsTargetPlatformVersion)\um</AdditionalIncludeDirectories>
    </FxCompile>
  </ItemGroup>

  <!-- Runtime de Win2D junto al exe (unpackaged no lo copia solo). -->
  <Target Name="CopyWin2DRuntime" AfterTargets="Build">
    <Copy SourceFiles="C:\Users\DarkW\.nuget\packages\microsoft.graphics.win2d\1.2.0\runtimes\win-x64\native\Microsoft.Graphics.Canvas.dll"
          DestinationFolder="$(OutDir)"
          SkipUnchangedFiles="true"
          Condition="Exists('C:\Users\DarkW\.nuget\packages\microsoft.graphics.win2d\1.2.0\runtimes\win-x64\native\Microsoft.Graphics.Canvas.dll')" />
  </Target>

  <!-- NO PackageReferences here. They are ALL in Directory.Build.props. -->

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <ImportGroup Label="ExtensionTargets">
  </ImportGroup>
</Project>
