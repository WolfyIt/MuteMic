<!-- MainWindow.xaml — MuteMic settings window (fixed size, dos vistas).
     Brushes de superficie via {ThemeResource} → el toggle Acrylic/Glass
     cambia todo en vivo con root.RequestedTheme().
     IMPORTANTE: cada x:Name nuevo debe reflejarse a mano en
     Generated Files\MainWindow.xaml.g.h. -->

<Window
    x:Class="MuteMic.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="MuteMic">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Custom title bar ══ -->
        <Grid Grid.Row="0" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0" Spacing="10">
                <TextBlock Text="MUTEMIC" FontFamily="Consolas" FontSize="13"
                           FontWeight="Bold" CharacterSpacing="300"
                           Foreground="{ThemeResource NssTextBrush}"/>
                <TextBlock x:Name="TitleStateBadge" Text="" FontFamily="Consolas" FontSize="11"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource NssGreenBrush}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource NssCaptionButtonStyle}" Click="OnToggleSettings">
                    <FontIcon x:Name="SettingsGlyph" Glyph="&#xE713;" FontSize="12"/>
                </Button>
                <Button Style="{StaticResource NssCaptionButtonStyle}" Click="OnMinimize">
                    <FontIcon Glyph="&#xE921;" FontSize="10"/>
                </Button>
                <Button Style="{StaticResource NssCaptionButtonStyle}" Click="OnCloseToTray">
                    <FontIcon Glyph="&#xE8BB;" FontSize="10"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ══ MAIN VIEW ══ -->
        <StackPanel x:Name="MainView" Grid.Row="1" Padding="18,6,18,26" Spacing="12">

            <!-- ── STATUS ── -->
            <Border Style="{StaticResource NssCardStyle}">
                <StackPanel Spacing="10">
                    <!-- Header con los controles ARRIBA: no pelean espacio
                         con el nombre del dispositivo. -->
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="STATUS" Style="{StaticResource NssHeaderStyle}"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="MuteBtn" Grid.Column="2" VerticalAlignment="Center"
                                Style="{StaticResource NssChipButtonStyle}"
                                MinWidth="96"
                                Click="OnToggleMute" Content="Mute"/>
                    </Grid>
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse x:Name="StateDot" Width="12" Height="12"
                                 VerticalAlignment="Center"
                                 Fill="{StaticResource NssGreenBrush}"/>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock x:Name="StateText" Text="—"
                                       Style="{StaticResource NssValueStyle}"/>
                            <TextBlock x:Name="DeviceText" Text=""
                                       Style="{StaticResource NssLabelStyle}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>
                    <Grid>
                        <Border x:Name="LevelTrack" Height="6" CornerRadius="3"
                                Background="{ThemeResource NssTrackBrush}"/>
                        <Border x:Name="LevelFill" Height="6" CornerRadius="3"
                                HorizontalAlignment="Stretch"
                                RenderTransformOrigin="0,0.5"
                                Background="{StaticResource NssGreenBrush}">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="LevelScale" ScaleX="0"/>
                            </Border.RenderTransform>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── SHORTCUTS (cards dinámicas construidas en código) ── -->
            <Border Style="{StaticResource NssCardStyle}">
                <StackPanel Spacing="10">
                    <Grid>
                        <TextBlock Text="SHORTCUTS" Style="{StaticResource NssHeaderStyle}"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="AddShortcutBtn" HorizontalAlignment="Right"
                                Style="{StaticResource NssChipButtonStyle}" Padding="10,4,10,4"
                                Click="OnAddShortcut" Content="&#xFF0B; Add"
                                ToolTipService.ToolTip="Add a shortcut card. Bind captures the first input you press — a key, a mouse button (middle/M4/M5) or a controller button — and each card has its own Toggle / Push-to-talk / Push-to-mute mode."/>
                    </Grid>
                    <StackPanel x:Name="ShortcutList" Spacing="8"/>
                    <TextBlock Style="{StaticResource NssLabelStyle}" TextWrapping="Wrap"
                               Text="Bind detects the device automatically: keyboard (any key or combo, incl. macro keys), mouse (middle/M4/M5) or XInput controller. Controller cards dim when no pad is connected. CLI: MuteMic.exe --toggle / --mute / --unmute / --show."/>
                </StackPanel>
            </Border>

            <!-- ── INPUT DEVICE ── -->
            <Border Style="{StaticResource NssCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="INPUT DEVICE" Style="{StaticResource NssHeaderStyle}"/>
                    <ComboBox x:Name="DeviceCombo" HorizontalAlignment="Stretch"
                              SelectionChanged="OnDeviceChanged"/>
                    <TextBlock Style="{StaticResource NssLabelStyle}"
                               Text="The shortcut mutes this device. «System default» follows Windows' default mic."
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- ══ SETTINGS VIEW ══ -->
        <StackPanel x:Name="SettingsView" Grid.Row="1" Padding="18,6,18,26" Spacing="12"
                    Visibility="Collapsed">

            <Border Style="{StaticResource NssCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="OPTIONS" Style="{StaticResource NssHeaderStyle}"/>
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Start with Windows" Style="{StaticResource NssOptionLabelStyle}"
                                   ToolTipService.ToolTip="Adds MuteMic to your user's startup apps (HKCU Run key). No admin rights needed."/>
                        <ToggleButton x:Name="AutostartToggle" Grid.Column="1"
                                      Style="{StaticResource NssPillToggleStyle}" Click="OnOptionToggled"/>
                        <TextBlock x:Name="StartTrayLabel" Grid.Column="2" Text="Start in tray"
                                   Style="{StaticResource NssOptionLabelStyle}" Margin="6,0,0,0"
                                   ToolTipService.ToolTip="Launch minimized to the tray — no window pops up when Windows starts."/>
                        <ToggleButton x:Name="StartTrayToggle" Grid.Column="3"
                                      Style="{StaticResource NssPillToggleStyle}" Click="OnOptionToggled"/>
                    </Grid>
                    <Grid ToolTipService.ToolTip="Plays the selected cue whenever the mic is muted or unmuted — pick the tones in the SOUND section below.">
                        <TextBlock Text="Sound on mute/unmute" Style="{StaticResource NssOptionLabelStyle}"/>
                        <ToggleButton x:Name="SoundToggle" HorizontalAlignment="Right"
                                      Style="{StaticResource NssPillToggleStyle}" Click="OnOptionToggled"/>
                    </Grid>
                    <!-- Dos toggles de tooltip en una sola fila (compacto). -->
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Tooltip: device" Style="{StaticResource NssOptionLabelStyle}"
                                   ToolTipService.ToolTip="Shows the exact input device name when you hover the tray icon."/>
                        <ToggleButton x:Name="TipDeviceToggle" Grid.Column="1"
                                      Style="{StaticResource NssPillToggleStyle}" Click="OnOptionToggled"/>
                        <TextBlock Grid.Column="2" Text="Tooltip: shortcut" Style="{StaticResource NssOptionLabelStyle}"
                                   Margin="6,0,0,0"
                                   ToolTipService.ToolTip="Shows the global shortcut in the tray icon tooltip."/>
                        <ToggleButton x:Name="TipShortcutToggle" Grid.Column="3"
                                      Style="{StaticResource NssPillToggleStyle}" Click="OnOptionToggled"/>
                    </Grid>
                    <Grid ToolTipService.ToolTip="Suspends the keyboard hook and the level meter. The shortcut stops working; the tray icon goes gray. Muting from the tray still works.">
                        <TextBlock Text="Pause service (hook + meter)" Style="{StaticResource NssOptionLabelStyle}"/>
                        <ToggleButton x:Name="PauseToggle" HorizontalAlignment="Right"
                                      Style="{StaticResource NssPillToggleStyle}" Click="OnOptionToggled"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── THEME ── -->
            <Border Style="{StaticResource NssCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="THEME" Style="{StaticResource NssHeaderStyle}"/>
                    <Grid ToolTipService.ToolTip="Switches the whole app (and the tray menu) between Light and Night surfaces.">
                        <TextBlock Text="Appearance (Light / Night)" Style="{StaticResource NssOptionLabelStyle}"/>
                        <ToggleButton x:Name="ThemeModeToggle" HorizontalAlignment="Right"
                                      Style="{StaticResource NssSunMoonToggleStyle}" Click="OnAppearanceToggled"/>
                    </Grid>
                    <!-- Liquid Glass + Frosting en una fila (compacto). -->
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Liquid Glass" Style="{StaticResource NssOptionLabelStyle}"
                                   ToolTipService.ToolTip="Real refraction shader (ported from an OpenGL Liquid Glass demo): the window becomes a lens over your desktop, rendered from a live screen capture on the GPU. Heads-up: while enabled, this window won't appear in screenshots or recordings (it must exclude itself from capture to avoid an infinite mirror), and GPU use rises slightly when things move behind the window."/>
                        <ToggleButton x:Name="GlassToggle" Grid.Column="1"
                                      Style="{StaticResource NssPillToggleStyle}" Click="OnGlassToggled"/>
                        <TextBlock x:Name="FrostLabel" Grid.Column="2" Text="Frosting"
                                   Style="{StaticResource NssOptionLabelStyle}"
                                   Margin="6,0,0,0"
                                   ToolTipService.ToolTip="ON = frosted glass (adds blur, noise and glow — the 'full effect'). OFF = crystal-clear glass with edge refraction only. Frosting costs a bit more GPU."/>
                        <ToggleButton x:Name="FrostToggle" Grid.Column="3"
                                      Style="{StaticResource NssPillToggleStyle}" Click="OnFrostToggled"/>
                    </Grid>
                    <!-- ── VISUAL CUE ── -->
                    <Grid ColumnSpacing="8"
                          ToolTipService.ToolTip="On-screen confirmation when you mute/unmute — for games and full-screen apps. Pure overlay: click-through, never steals keyboard focus. Green = live, red = muted.">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Visual cue" Style="{StaticResource NssOptionLabelStyle}"/>
                        <!-- Single-select unido, cuadrado, cada botón con el
                             DIBUJO de su estilo (no texto). -->
                        <ToggleButton x:Name="CueOffBtn" Grid.Column="1"
                                      Style="{StaticResource NssSegmentStyle}"
                                      Width="46" Height="32" Padding="0"
                                      CornerRadius="8,0,0,8" Margin="0,0,-1,0"
                                      Click="OnCueStyleSelected"
                                      ToolTipService.ToolTip="No visual cue.">
                            <FontIcon Glyph="&#xE711;" FontSize="11"/>
                        </ToggleButton>
                        <ToggleButton x:Name="CueEdgesBtn" Grid.Column="2"
                                      Style="{StaticResource NssSegmentStyle}"
                                      Width="46" Height="32" Padding="0"
                                      CornerRadius="0" Margin="0,0,-1,0"
                                      Click="OnCueStyleSelected"
                                      ToolTipService.ToolTip="Soft glow strips along the screen borders + tiny mic badge (top-left).">
                            <Border Width="20" Height="13" CornerRadius="3"
                                    BorderBrush="{ThemeResource NssTextBrush}"
                                    BorderThickness="1.5"/>
                        </ToggleButton>
                        <ToggleButton x:Name="CueCornersBtn" Grid.Column="3"
                                      Style="{StaticResource NssSegmentStyle}"
                                      Width="46" Height="32" Padding="0"
                                      CornerRadius="0" Margin="0,0,-1,0"
                                      Click="OnCueStyleSelected"
                                      ToolTipService.ToolTip="Same glow, corners only + tiny mic badge.">
                            <Grid Width="20" Height="13">
                                <Border Width="7" Height="6" HorizontalAlignment="Left" VerticalAlignment="Top"
                                        BorderBrush="{ThemeResource NssTextBrush}" BorderThickness="1.5,1.5,0,0" CornerRadius="3,0,0,0"/>
                                <Border Width="7" Height="6" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        BorderBrush="{ThemeResource NssTextBrush}" BorderThickness="0,1.5,1.5,0" CornerRadius="0,3,0,0"/>
                                <Border Width="7" Height="6" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                        BorderBrush="{ThemeResource NssTextBrush}" BorderThickness="1.5,0,0,1.5" CornerRadius="0,0,0,3"/>
                                <Border Width="7" Height="6" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        BorderBrush="{ThemeResource NssTextBrush}" BorderThickness="0,0,1.5,1.5" CornerRadius="0,0,3,0"/>
                            </Grid>
                        </ToggleButton>
                        <ToggleButton x:Name="CueNotchBtn" Grid.Column="4"
                                      Style="{StaticResource NssSegmentStyle}"
                                      Width="46" Height="32" Padding="0"
                                      CornerRadius="0,8,8,0"
                                      Click="OnCueStyleSelected"
                                      ToolTipService.ToolTip="Droplet-shaped island sliding in from the screen edge (pick the edge below). On the bottom edge it emerges from the taskbar.">
                            <Grid Width="20" Height="13">
                                <Border CornerRadius="3"
                                        BorderBrush="{ThemeResource NssTextSecondaryBrush}"
                                        BorderThickness="1"/>
                                <Rectangle x:Name="CueNotchGlyph" Width="9" Height="3.5"
                                           RadiusX="1.75" RadiusY="1.75"
                                           Fill="{ThemeResource NssTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Top"/>
                            </Grid>
                        </ToggleButton>
                    </Grid>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Notch edge" Style="{StaticResource NssOptionLabelStyle}"/>
                        <ComboBox x:Name="CuePosCombo" Grid.Column="1" FontSize="12" MinWidth="110"
                                  SelectionChanged="OnCuePosChanged"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── SOUND ── -->
            <Border Style="{StaticResource NssCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="SOUND" Style="{StaticResource NssHeaderStyle}"/>
                    <!-- Ambos cues en una fila (compacto). -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Mute" Style="{StaticResource NssOptionLabelStyle}"/>
                        <ComboBox x:Name="MuteSoundCombo" Grid.Column="1" FontSize="12"
                                  HorizontalAlignment="Stretch" SelectionChanged="OnSoundChanged"/>
                        <TextBlock Grid.Column="2" Text="Unmute" Style="{StaticResource NssOptionLabelStyle}"
                                   Margin="6,0,0,0"/>
                        <ComboBox x:Name="UnmuteSoundCombo" Grid.Column="3" FontSize="12"
                                  HorizontalAlignment="Stretch" SelectionChanged="OnSoundChanged"/>
                    </Grid>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="86"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Volume" Style="{StaticResource NssOptionLabelStyle}"/>
                        <Slider x:Name="VolumeSlider" Grid.Column="1" Minimum="0" Maximum="100"
                                StepFrequency="1" ValueChanged="OnVolumeChanged"
                                Foreground="{StaticResource NssGreenBrush}"/>
                    </Grid>
                    <TextBlock Style="{StaticResource NssLabelStyle}" TextWrapping="Wrap"
                               Text="Drop your own WAVs into the Sounds folder next to the exe — the lists refresh every time you open this page. Picking one previews it."/>
                </StackPanel>
            </Border>

            <Button HorizontalAlignment="Stretch" Click="OnExit"
                    Margin="0,2,0,2"
                    Background="#52FF3131"
                    Foreground="{StaticResource NssRedBrush}"
                    BorderBrush="#66FF3131"
                    BorderThickness="1" CornerRadius="8" Padding="0,10,0,10"
                    Content="Quit MuteMic"/>

        </StackPanel>
    </Grid>
</Window>
