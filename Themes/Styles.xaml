<!-- Styles.xaml — Estilos de MuteMic. Los brushes que cambian con el tema
     usan {ThemeResource}; los acentos neón son compartidos. -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══ Module Card ══ -->
    <Style x:Key="NssCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource NssCardBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource NssBorderBrush}"/>
        <Setter Property="BorderThickness" Value="{StaticResource NssCardBorder}"/>
        <Setter Property="CornerRadius" Value="{StaticResource NssCardRadius}"/>
        <Setter Property="Padding" Value="{StaticResource NssCardPadding}"/>
    </Style>

    <!-- ══ Section Header ══ -->
    <Style x:Key="NssHeaderStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource NssTextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="CharacterSpacing" Value="180"/>
        <Setter Property="FontFamily" Value="Consolas"/>
    </Style>

    <!-- ══ Value Display ══ -->
    <Style x:Key="NssValueStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource NssTextBrush}"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Light"/>
    </Style>

    <!-- ══ Label / Caption ══ -->
    <Style x:Key="NssLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource NssTextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <!-- ══ Mono value ══ -->
    <Style x:Key="NssMonoStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource NssCyanBrush}"/>
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- ══ Pill Toggle (custom) ══ -->
    <Style x:Key="NssPillToggleStyle" TargetType="ToggleButton">
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="UseSystemFocusVisuals" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid>
                        <Border x:Name="Track" CornerRadius="13"
                                Background="{ThemeResource NssControlFillBrush}"
                                BorderBrush="{ThemeResource NssBorderBrush}"
                                BorderThickness="1"/>
                        <Ellipse x:Name="Knob" Width="18" Height="18"
                                 Fill="White"
                                 HorizontalAlignment="Left"
                                 Margin="4,0,0,0"/>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Track.Background" Value="{ThemeResource NssCardHoverBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="Track.Background" Value="{ThemeResource NssCardHoverBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <!-- Deshabilitado: atenuado, claramente fuera de alcance. -->
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Track.Opacity" Value="0.35"/>
                                        <Setter Target="Knob.Opacity" Value="0.35"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Checked">
                                    <VisualState.Setters>
                                        <Setter Target="Track.Background" Value="{ThemeResource NssToggleOnBrush}"/>
                                        <Setter Target="Track.BorderBrush" Value="{ThemeResource NssToggleOnBrush}"/>
                                        <Setter Target="Knob.HorizontalAlignment" Value="Right"/>
                                        <Setter Target="Knob.Margin" Value="0,0,4,0"/>
                                        <Setter Target="Knob.Fill" Value="White"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="CheckedPointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Track.Background" Value="{ThemeResource NssToggleOnBrush}"/>
                                        <Setter Target="Track.BorderBrush" Value="{ThemeResource NssToggleOnBrush}"/>
                                        <Setter Target="Knob.HorizontalAlignment" Value="Right"/>
                                        <Setter Target="Knob.Margin" Value="0,0,4,0"/>
                                        <Setter Target="Knob.Fill" Value="White"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="CheckedPressed">
                                    <VisualState.Setters>
                                        <Setter Target="Track.Background" Value="{ThemeResource NssToggleOnBrush}"/>
                                        <Setter Target="Track.BorderBrush" Value="{ThemeResource NssToggleOnBrush}"/>
                                        <Setter Target="Knob.HorizontalAlignment" Value="Right"/>
                                        <Setter Target="Knob.Margin" Value="0,0,4,0"/>
                                        <Setter Target="Knob.Fill" Value="White"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ Sun/Moon toggle (Light/Night — como el ref del usuario):
         Night: pastilla oscura, knob blanco a la izquierda, luna a la derecha.
         Light: pastilla blanca, sol naranja a la izquierda, knob ámbar a la derecha. -->
    <Style x:Key="NssSunMoonToggleStyle" TargetType="ToggleButton">
        <Setter Property="Width" Value="64"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="UseSystemFocusVisuals" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid>
                        <Border x:Name="Track" CornerRadius="15"
                                Background="#FF262B36"
                                BorderBrush="#3AFFFFFF"
                                BorderThickness="1"/>
                        <FontIcon x:Name="SunIcon" Glyph="&#xE706;" FontSize="13"
                                  Foreground="#FFF0A93B" Opacity="0"
                                  HorizontalAlignment="Left" Margin="9,0,0,0"/>
                        <FontIcon x:Name="MoonIcon" Glyph="&#xE708;" FontSize="12"
                                  Foreground="#FFEDEFF4" Opacity="1"
                                  HorizontalAlignment="Right" Margin="0,0,9,0"/>
                        <Ellipse x:Name="Knob" Width="22" Height="22"
                                 Fill="#FFF2F2F2"
                                 HorizontalAlignment="Left" Margin="4,0,0,0"/>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <!-- Estados hover/pressed SIN marcar: deben existir aunque
                                     vacíos — si el VSM transiciona a un estado indefinido,
                                     los setters del estado anterior se quedan pegados
                                     (el "toggle bugeado" con el mouse encima). -->
                                <VisualState x:Name="PointerOver"/>
                                <VisualState x:Name="Pressed"/>
                                <VisualState x:Name="Checked">
                                    <VisualState.Setters>
                                        <Setter Target="Track.Background" Value="#FFFFFFFF"/>
                                        <Setter Target="Track.BorderBrush" Value="#FFE9CFA0"/>
                                        <Setter Target="SunIcon.Opacity" Value="1"/>
                                        <Setter Target="MoonIcon.Opacity" Value="0"/>
                                        <Setter Target="Knob.HorizontalAlignment" Value="Right"/>
                                        <Setter Target="Knob.Margin" Value="0,0,4,0"/>
                                        <Setter Target="Knob.Fill" Value="#FFF6B24E"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="CheckedPointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Track.Background" Value="#FFFFFFFF"/>
                                        <Setter Target="Track.BorderBrush" Value="#FFE9CFA0"/>
                                        <Setter Target="SunIcon.Opacity" Value="1"/>
                                        <Setter Target="MoonIcon.Opacity" Value="0"/>
                                        <Setter Target="Knob.HorizontalAlignment" Value="Right"/>
                                        <Setter Target="Knob.Margin" Value="0,0,4,0"/>
                                        <Setter Target="Knob.Fill" Value="#FFF6B24E"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="CheckedPressed">
                                    <VisualState.Setters>
                                        <Setter Target="Track.Background" Value="#FFFFFFFF"/>
                                        <Setter Target="Track.BorderBrush" Value="#FFE9CFA0"/>
                                        <Setter Target="SunIcon.Opacity" Value="1"/>
                                        <Setter Target="MoonIcon.Opacity" Value="0"/>
                                        <Setter Target="Knob.HorizontalAlignment" Value="Right"/>
                                        <Setter Target="Knob.Margin" Value="0,0,4,0"/>
                                        <Setter Target="Knob.Fill" Value="#FFF6B24E"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ Segment pill (con nombre) ══ -->
    <Style x:Key="NssSegmentStyle" TargetType="ToggleButton">
        <Setter Property="Height" Value="34"/>
        <Setter Property="Padding" Value="16,0,16,0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="CornerRadius" Value="17"/>
        <Setter Property="UseSystemFocusVisuals" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bg" CornerRadius="{TemplateBinding CornerRadius}"
                            Background="{ThemeResource NssControlFillBrush}"
                            BorderBrush="{ThemeResource NssBorderBrush}"
                            BorderThickness="1"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter x:Name="CP"
                                          Foreground="{ThemeResource NssTextSecondaryBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Bg.Background" Value="{ThemeResource NssCardHoverBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Checked">
                                    <VisualState.Setters>
                                        <Setter Target="Bg.Background" Value="{StaticResource NssCyanDimBrush}"/>
                                        <Setter Target="Bg.BorderBrush" Value="{StaticResource NssCyanBrush}"/>
                                        <Setter Target="CP.Foreground" Value="{StaticResource NssCyanBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="CheckedPointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Bg.Background" Value="{StaticResource NssCyanDimBrush}"/>
                                        <Setter Target="Bg.BorderBrush" Value="{StaticResource NssCyanBrush}"/>
                                        <Setter Target="CP.Foreground" Value="{StaticResource NssCyanBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ Botón chip ══ -->
    <Style x:Key="NssChipButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource NssControlFillBrush}"/>
        <Setter Property="Foreground" Value="{ThemeResource NssTextBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource NssBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,7,14,7"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- ══ Botón caption ══ -->
    <Style x:Key="NssCaptionButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{ThemeResource NssTextDimBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="UseSystemFocusVisuals" Value="False"/>
    </Style>

    <!-- ══ TextBox ══ -->
    <Style x:Key="NssTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{ThemeResource NssControlFillBrush}"/>
        <Setter Property="Foreground" Value="{ThemeResource NssTextBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource NssBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- ══ Fila de opción ══ -->
    <Style x:Key="NssOptionLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource NssTextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

</ResourceDictionary>
